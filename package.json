{
    "name": "cf7-nova-lite",
    "version": "2.0.0-dev",
    "private": true,
    "description": "Build pipeline for CF7 Nova Lite admin UI (React + Vite).",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint \"ui/**/*.{js,jsx}\"",
        "lint:fix": "eslint \"ui/**/*.{js,jsx}\" --fix",
        "format": "prettier --write \"ui/**/*.{js,jsx,css,scss,json,md}\""
    },
    "dependencies": {
        "@dnd-kit/core": "^6.1.0",
        "@dnd-kit/sortable": "^8.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    },
    "devDependencies": {
        "@vitejs/plugin-react": "^4.3.1",
        "@wordpress/api-fetch": "^7.5.0",
        "@wordpress/components": "^28.5.0",
        "@wordpress/element": "^6.5.0",
        "@wordpress/eslint-plugin": "^20.2.0",
        "@wordpress/i18n": "^5.5.0",
        "eslint": "^8.57.0",
        "prettier": "^3.3.3",
        "sass": "^1.77.8",
        "vite": "^5.4.2"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    },
    "browserslist": [
        "extends @wordpress/browserslist-config"
    ]
}
